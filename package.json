{
  "name": "tailwindcss-mangle",
  "type": "module",
  "version": "4.0.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "dev": "pnpm -r run dev",
    "test": "turbo run test --filter=./packages/*",
    "test:types": "turbo run test:types --filter=./packages/*",
    "check:boundaries": "node scripts/check-package-boundaries.mjs",
    "lint:style": "pnpm exec stylelint \"{website,packages,apps}/**/*.{css,scss}\" --allow-empty-input",
    "test:e2e": "pnpm run test:e2e:apps",
    "test:e2e:apps": "cross-env TWM_APPS_E2E=1 vitest run --config e2e/vitest.config.ts e2e/apps.e2e.test.ts",
    "test:e2e:pw": "pnpm run test:e2e:apps:pw",
    "test:e2e:apps:pw": "cross-env TWM_APPS_E2E_PLAYWRIGHT=1 vitest run --config e2e/vitest.config.ts e2e/apps.playwright.e2e.test.ts",
    "test:e2e:hmr": "pnpm run test:e2e:apps:hmr",
    "test:e2e:apps:hmr": "cross-env TWM_APPS_E2E_HMR=1 vitest run --config e2e/vitest.config.ts e2e/apps.hmr.e2e.test.ts",
    "test:e2e:all": "pnpm run test:e2e:apps && pnpm run test:e2e:apps:pw && pnpm run test:e2e:apps:hmr",
    "test:dev": "vitest",
    "build:docs": "turbo run build --filter=./website",
    "lint": "eslint \"packages/**/*.ts\" packages/tailwindcss-patch/tsdown.config.mts \"e2e/**/*.ts\" scripts/check-package-boundaries.mjs --ignore-pattern \"packages/**/bench/**\" --ignore-pattern \"packages/**/test-d/**\" --fix",
    "preinstall": "npx only-allow pnpm",
    "sync": "cnpm sync @tailwindcss-mangle/shared @tailwindcss-mangle/config @tailwindcss-mangle/engine tailwindcss-patch unplugin-tailwindcss-mangle @tailwindcss-mangle/core",
    "publish-packages": "pnpm run build && pnpm run test && changeset version && changeset publish",
    "-------": "-----------",
    "release": "changeset",
    "release:verify": "pnpm check:boundaries && pnpm build && pnpm test && pnpm test:e2e",
    "pr": "changeset pre enter alpha",
    "pr:beta": "changeset pre enter beta",
    "pr:rc": "changeset pre enter rc",
    "pr:exit": "changeset pre exit",
    "cv": "changeset version ",
    "--------": "----------------",
    "_postinstall": "tw-patch install",
    "script:init": "monorepo init",
    "script:sync": "monorepo sync",
    "script:clean": "monorepo clean",
    "script:mirror": "monorepo mirror",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/prompt-cli": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@icebreakers/changelog-github": "^1.0.2",
    "@icebreakers/commitlint-config": "^3.0.1",
    "@icebreakers/eslint-config": "^5.0.4",
    "@icebreakers/monorepo": "^4.0.13",
    "@icebreakers/stylelint-config": "^4.0.2",
    "@playwright/test": "^1.61.0",
    "@rollup/pluginutils": "^5.4.0",
    "@tailwindcss-mangle/core": "workspace:*",
    "@tailwindcss-mangle/shared": "workspace:*",
    "@tailwindcss/postcss": "^4.3.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__helper-plugin-utils": "^7.10.3",
    "@types/babel__traverse": "^7.28.0",
    "@types/fs-extra": "^11.0.4",
    "@types/get-value": "^3.0.5",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/klaw": "^3.0.7",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^26.0.0",
    "@types/resolve": "^1.20.6",
    "@types/semver": "^7.7.1",
    "@types/set-value": "^4.0.3",
    "@vitest/coverage-v8": "~4.1.9",
    "astro": "^6.4.7",
    "ci-info": "^4.4.0",
    "comment-json": "^5.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "dedent": "^1.7.2",
    "defu": "^6.1.7",
    "del": "^8.0.1",
    "dotenv": "^17.4.2",
    "es-toolkit": "^1.48.1",
    "eslint": "^10.5.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fdir": "^6.5.0",
    "fs-extra": "^11.3.5",
    "get-value": "^4.1.0",
    "html-minifier-terser": "^7.2.0",
    "html-webpack-plugin": "^5.6.7",
    "husky": "^9.1.7",
    "klaw": "^4.1.0",
    "lint-staged": "^17.0.8",
    "local-pkg": "^1.2.1",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "micromatch": "^4.0.8",
    "mini-css-extract-plugin": "^2.10.2",
    "normalize-newline": "^5.0.0",
    "only-allow": "^1.2.2",
    "pathe": "^2.0.3",
    "picomatch": "^4.0.4",
    "pkg-types": "^2.3.1",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "postcss7": "npm:postcss@7",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "set-value": "^4.1.0",
    "stylelint": "^17.13.0",
    "tailwindcss": "catalog:tailwindcss3",
    "tailwindcss-patch": "workspace:*",
    "tailwindcss2": "catalog:tailwindcss2",
    "tsd": "^0.33.0",
    "tsdown": "^0.22.3",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "unplugin": "^3.0.0",
    "unplugin-tailwindcss-mangle": "workspace:*",
    "vite": "^8.1.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "~4.1.9",
    "webpack": "^5.107.2",
    "webpack-build-utils": "^0.0.7",
    "yaml": "^2.9.0"
  }
}
