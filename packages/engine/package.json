{
  "name": "@tailwindcss-mangle/engine",
  "type": "module",
  "version": "0.1.0",
  "description": "Tailwind CSS candidate extraction and style generation engine for tailwindcss-mangle",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "homepage": "https://mangle.icebreaker.top/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/tailwindcss-mangle.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/tailwindcss-mangle/issues"
  },
  "keywords": [
    "tailwindcss",
    "engine",
    "extract",
    "class",
    "mangle"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./v3": {
      "types": "./dist/v3/index.d.ts",
      "import": "./dist/v3/index.js",
      "require": "./dist/v3/index.cjs"
    },
    "./v4": {
      "types": "./dist/v4/index.d.ts",
      "import": "./dist/v4/index.js",
      "require": "./dist/v4/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "v3": [
        "./dist/v3/index.d.ts"
      ],
      "v4": [
        "./dist/v4/index.d.ts"
      ],
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.20.0"
  },
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown",
    "test": "vitest run --coverage.enabled",
    "test:dev": "vitest",
    "typecheck": "tsc --noEmit",
    "test:types": "pnpm typecheck && pnpm build && tsd --typings dist/index.d.ts --files test-d/**/*.test-d.ts",
    "bench": "node --import tsx bench/performance.ts",
    "bench:small": "cross-env TWM_ENGINE_BENCH_SCALE=small node --import tsx bench/performance.ts",
    "bench:large": "cross-env TWM_ENGINE_BENCH_SCALE=large node --import tsx bench/performance.ts",
    "bench:clean": "node --import tsx bench/performance.ts --clean",
    "smoke:node18": "node scripts/node18-smoke.mjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./v3": {
        "types": "./dist/v3/index.d.ts",
        "import": "./dist/v3/index.js",
        "require": "./dist/v3/index.cjs"
      },
      "./v4": {
        "types": "./dist/v4/index.d.ts",
        "import": "./dist/v4/index.js",
        "require": "./dist/v4/index.cjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "peerDependencies": {
    "tailwindcss": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@tailwindcss/node": "^4.3.1",
    "@tailwindcss/oxide": "^4.3.1",
    "micromatch": "^4.0.8",
    "pathe": "^2.0.3",
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "htmlparser2": "12.0.0",
    "tailwindcss": "^4.3.1",
    "tailwindcss-3": "catalog:tailwindcss3"
  }
}
